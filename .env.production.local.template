# ============================================================================
# CONFIGURATION PRODUCTION - RÉSEAU LOCAL HORS LIGNE
# Application Gestion Fonds DGDADPKV
# ============================================================================
# Ce fichier configure l'application pour fonctionner en mode 100% local
# sans connexion Internet
# ============================================================================

# ====================
# MODE DE FONCTIONNEMENT
# ====================

# Mode : local (pas de cloud)
VITE_MODE=local

# Mode hors ligne activé (désactive toutes les requêtes externes)
VITE_OFFLINE_MODE=true

# Environnement
NODE_ENV=production

# ====================
# SERVEUR LOCAL
# ====================

# IP du serveur (à adapter selon votre réseau)
# Exemples : 192.168.1.100, 192.168.0.50, 10.0.0.10
VITE_SERVER_IP=192.168.1.100

# Port de l'application web (Nginx)
VITE_SERVER_PORT=80

# ====================
# BASE DE DONNÉES  POSTGRESQL
# ====================

# Hôte de la base de données (IP du serveur)
VITE_DB_HOST=192.168.1.100

# Port PostgreSQL
VITE_DB_PORT=5432

# Nom de la base de données
VITE_DB_NAME=gestion_fonds_dgdadpkv

# Utilisateur PostgreSQL (NE PAS mettre le mot de passe ici pour sécurité)
VITE_DB_USER=postgres

# ====================
# SUPABASE LOCAL (si utilisé)
# ====================

# URL Supabase local
# Format : http://[IP_SERVEUR]:54321
VITE_SUPABASE_URL=http://192.168.1.100:54321

# Clé publique Supabase local (clé par défaut de Supabase local)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# ====================
# DÉSACTIVATION DES SERVICES EXTERNES
# ====================

# Analytics désactivées (pas de Google Analytics, Matomo, etc.)
VITE_DISABLE_ANALYTICS=true

# Polices externes désactivées (Google Fonts, etc.)
# Les polices sont incluses dans le bundle
VITE_DISABLE_EXTERNAL_FONTS=true

# CDN désactivés (pas de Bootstrap CDN, jQuery CDN, etc.)
VITE_DISABLE_CDN=true

# Télémétrie désactivée
VITE_DISABLE_TELEMETRY=true

# Mise à jour automatique désactivée
VITE_DISABLE_AUTO_UPDATE=true

# ====================
# CACHE ET PERFORMANCE
# ====================

# Activer le cache local (localStorage, IndexedDB)
VITE_ENABLE_LOCAL_CACHE=true

# Durée du cache en secondes (24h)
VITE_CACHE_DURATION=86400

# Activer le Service Worker pour mode hors ligne avancé
VITE_ENABLE_SERVICE_WORKER=true

# ====================
# SÉCURITÉ
# ====================

# Forcer HTTPS (désactivé pour réseau local)
VITE_FORCE_HTTPS=false

# Allowed origins (liste des IPs autorisées, séparées par des virgules)
VITE_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://192.168.1.100,http://192.168.1.0/24

# Session timeout en minutes (30 minutes)
VITE_SESSION_TIMEOUT=30

# ====================
# LOGGING ET DEBUG
# ====================

# Mode debug (désactiver en production)
VITE_DEBUG=false

# Logs console (désactiver en production)
VITE_ENABLE_CONSOLE_LOGS=false

# Niveau de log : error, warn, info, debug
VITE_LOG_LEVEL=error

# ====================
# FONCTIONNALITÉS
# ====================

# Activer l'export Excel/PDF
VITE_ENABLE_EXPORT=true

# Activer les rapports
VITE_ENABLE_REPORTS=true

# Activer l'audit log
VITE_ENABLE_AUDIT_LOG=true

# Activer la gestion multi-utilisateurs
VITE_ENABLE_MULTI_USER=true

# ====================
# LIMITES ET QUOTAS
# ====================

# Nombre maximum d'enregistrements par page
VITE_MAX_RECORDS_PER_PAGE=100

# Taille maximale des fichiers uploadés (Mo)
VITE_MAX_UPLOAD_SIZE_MB=10

# Nombre maximum d'utilisateurs connectés simultanément (0 = illimité)
VITE_MAX_CONCURRENT_USERS=0

# ====================
# PERSONNALISATION
# ====================

# Nom de l'application
VITE_APP_NAME=Gestion Fonds DGDADPKV

# Version de l'application
VITE_APP_VERSION=1.0.0

# Organisation
VITE_ORGANIZATION_NAME=DGDA

# Langue par défaut
VITE_DEFAULT_LANGUAGE=fr

# Fuseau horaire
VITE_TIMEZONE=Africa/Kinshasa

# ====================
# MAINTENANCE
# ====================

# Mode maintenance (désactiver l'accès sauf pour les admins)
VITE_MAINTENANCE_MODE=false

# Message de maintenance
VITE_MAINTENANCE_MESSAGE=L'application est en cours de maintenance. Veuillez réessayer dans quelques minutes.

# ====================
# NOTES IMPORTANTES
# ====================
# 
# 1. CE FICHIER NE DOIT PAS CONTENIR DE MOTS DE PASSE
#    Les mots de passe sont gérés côté serveur uniquement
#
# 2. ADAPTER L'IP DU SERVEUR (VITE_SERVER_IP)
#    Remplacez 192.168.1.100 par l'IP réelle de votre serveur
#
# 3. RECOMPILER APRÈS MODIFICATION
#    Après toute modification, recompilez l'application :
#    npm run build
#
# 4. SAUVEGARDER CE FICHIER
#    Conservez une copie de ce fichier configuré
#
# ============================================================================
