# URL Supabase accessible depuis les clients LAN
# Format : https://<IP_DU_SERVEUR>/api
VITE_SUPABASE_URL=https://192.168.1.100/api

# Clé publique Supabase (anon key – safe dans le frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
